# Copy to .env and fill in real values. Never commit .env.

NODE_ENV=development
PORT=9000
MONGODB_URI=

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

FRONTEND_URL=http://localhost:3000
CHROMA_URL=http://127.0.0.1:8000
VIRTUAL_TRY_ON_API_URL=

# Groq (chatbot LLM)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# PayOS
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_WEB_BASE_URL=https://pay.payos.vn/web

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google OAuth
GOOGLE_CLIENT_ID=

# Owner bootstrap (optional scripts)
OWNER_EMAIL=
OWNER_PHONE=
OWNER_NAME=
OWNER_PASSWORD=

# See codebase for optional CHATBOT_* and tuning variables.
# Hugging Face